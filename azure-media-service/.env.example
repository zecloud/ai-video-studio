# Shared secret desktop clients must present as `Authorization: Bearer <API_KEY>`.
# Required. Generate a strong random value, e.g.: openssl rand -base64 32
API_KEY=change-me-to-a-long-random-secret

# Azure Storage account name (without the .blob.core.windows.net suffix).
# Required.
STORAGE_ACCOUNT_NAME=myaivideostudiostorage

# Default blob container used when a request does not specify one.
# Optional. Defaults to "media-staging".
CONTAINER_NAME=media-staging

# TCP port the HTTP server listens on.
# Optional. Defaults to "8080".
PORT=8080

# Authentication to Azure Storage uses DefaultAzureCredential (Managed
# Identity in Azure Container Apps). No storage account key is required or
# read from the environment. When running locally, sign in with
# `az login` or set AZURE_CLIENT_ID / AZURE_TENANT_ID / AZURE_CLIENT_SECRET
# for a service principal — see azidentity docs for details.
