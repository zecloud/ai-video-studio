# Shared secret presented with the Authorization bearer scheme or X-API-Key header.
API_KEY=change-me-to-a-long-random-secret

# Process role: api, worker (Video Indexer), or ffmpeg-worker.
SERVICE_ROLE=api

# HTTP listen address for the API role.
LISTEN_ADDR=:8080

# Durable Task Scheduler endpoint and isolated role-specific task hubs.
# The API requires both hubs; each worker requires only its own hub.
DTS_ENDPOINT=https://<scheduler-name>.<region>.durabletask.io
DTS_TASK_HUB=video-indexer
DTS_RENDER_TASK_HUB=ffmpeg-render
DTS_CANCELLATION_GRACE=30s

# FFmpeg worker runtime settings.
FFMPEG_PATH=ffmpeg
RENDER_WORKSPACE_ROOT=/workspace/render
RENDER_TIMEOUT=2h

# Azure Storage account URL used with Microsoft Entra ID / managed identity.
AZURE_STORAGE_URL=https://<storage-account-name>.blob.core.windows.net/

# Blob containers for staged media and durable job documents.
STAGING_CONTAINER=video-indexer-staging
JOB_CONTAINER=video-indexer-jobs

# Queue and worker limits for the single-replica worker.
QUEUE_SIZE=16
WORKER_CONCURRENCY=1

# Short-lived user delegation SAS validity for staged blobs.
SAS_VALIDITY=2h

# Microsoft Graph base URL for OneDrive content downloads.
GRAPH_BASE_URL=https://graph.microsoft.com/v1.0

# Azure AI Video Indexer ARM/account configuration.
AZURE_VIDEO_INDEXER_SUBSCRIPTION_ID=
AZURE_VIDEO_INDEXER_RESOURCE_GROUP=
AZURE_VIDEO_INDEXER_ACCOUNT_NAME=
AZURE_VIDEO_INDEXER_ACCOUNT_ID=
AZURE_VIDEO_INDEXER_LOCATION=
AZURE_VIDEO_INDEXER_TIMEOUT=30m

# Azure Foundry edit-planner configuration.
FOUNDRY_PROJECT_ENDPOINT=https://<resource>.services.ai.azure.com/api/projects/<project>
# FOUNDRY_ENDPOINT and AZURE_FOUNDRY_ENDPOINT are accepted as legacy aliases.
FOUNDRY_DEPLOYMENT_NAME=gpt-5.4

# Telemetry export (optional).
# Use Application Insights in Azure or set OTEL_EXPORTER_OTLP_* for an OTLP collector.
APPLICATIONINSIGHTS_CONNECTION_STRING=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=azure-video-indexer-service
